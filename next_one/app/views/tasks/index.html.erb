<h2>今日やるべき1件</h2>

<% if @today_task.present? %>
  <p>
    <strong><%= @today_task.title %></strong><br>
    締切: <%= @today_task.due_on %><br>
    <%= @today_task.memo %>
  </p>
<% else %>
  <p>今日やるべきタスクはありません</p>
<% end %>

<hr>

<h1>タスク一覧</h1>

<%= link_to "タスク新規作成", new_task_path %>

<ul>
  <% @tasks.each do |task| %>
    <li style="<%= 'color:red;' if task.due_on <= Date.today + 1 %>">
      <strong><%= link_to task.title, task_path(task) %></strong>
      （締切: <%= task.due_on %> / あと <%= (task.due_on - Date.today).to_i %> 日）
      <br>
      <%= task.memo %>
      <br>

      <%= button_to (task.is_done ? "未完了に戻す" : "完了"), toggle_status_task_path(task), method: :patch %>

    </li>
  <% end %>
</ul>

<h2>期限切れタスク</h2>

<% if @overdue_tasks.present? %>
  <ul>
    <% @overdue_tasks.each do |task| %>
      <li>
        <strong><%= link_to task.title, task_path(task) %></strong>
        （締切: <%= task.due_on %> / 期限切れ）
        <br>
        <%= task.memo %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>期限切れタスクはありません</p>
<% end %>

<h2>完了済みタスク</h2>

<% if @completed_tasks.present? %>
  <ul>
    <% @completed_tasks.each do |task| %>
      <li>
        <strong><%= task.title %></strong>
        （締切: <%= task.due_on %>）
        <br>
        <%= task.memo %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>完了済みタスクはありません</p>
<% end %>

<%= link_to "トップページへ戻る", root_path %>